# mock (padrão), evolution, whatsapp ou instagram
MESSAGING_PROVIDER=mock
META_GRAPH_VERSION=v22.0

# Evolution API (gateway não-oficial de WhatsApp, bom para testes)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=oficina

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Instagram Messaging API (Meta)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Webhook de entrada da Meta
META_WEBHOOK_VERIFY_TOKEN=troque-por-um-segredo

# Configure no painel da Evolution API o webhook para:
# POST http://SEU_HOST:3001/webhooks/evolution (evento messages.upsert)
